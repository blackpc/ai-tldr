# Cloudflare Pages SPA fallback.
#
# Static files (including dist/releases/<id>/index.html and
# dist/influencers/index.html generated by scripts/prerender.ts) are
# always served first. This rule only kicks in for paths that don't
# match any existing file — in which case Pages serves /index.html
# with a 200 so client-side routing can handle it.
/*    /index.html   200
