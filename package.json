{
  "name": "tldr",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && bun scripts/check-feed.ts && vite build && bun scripts/prerender.ts",
    "typecheck": "tsc -b --noEmit && bun scripts/check-feed.ts",
    "lint": "eslint .",
    "preview": "bun run build && wrangler dev",
    "update-content": "echo 'Run an external Claude/agent with prompts/update-releases.md to refresh src/data/releases.json'",
    "deploy": "bun run build && wrangler deploy"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.2",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "wrangler": "^4.81.1"
  }
}
